generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Listener {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  fullName  String?
  passwordHash String?
  playlists Playlist[]
  reviews   Review[]
  follows   ArtistFollow[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Genre {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  songs     Song[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Artist {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  email     String   @unique  // Auto-generated: artist{id}@musicdb.com
  passwordHash String?
  albums    Album[]
  songs     Song[]
  followers ArtistFollow[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model ArtistFollow {
  listenerId Int
  artistId   Int
  createdAt  DateTime @default(now())

  listener Listener @relation(fields: [listenerId], references: [id], onDelete: Cascade)
  artist   Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([listenerId, artistId])
  @@index([artistId])
}

model Album {
  id          Int      @id @default(autoincrement())
  title       String
  releaseYear Int
  artistId    Int
  artist      Artist   @relation(fields: [artistId], references: [id])
  songs       Song[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([title, artistId, releaseYear])
}

model Song {
  id          Int        @id @default(autoincrement())
  title       String
  duration    Int
  albumId     Int?
  album       Album?     @relation(fields: [albumId], references: [id])
  artistId    Int
  artist      Artist     @relation(fields: [artistId], references: [id])
  genreId     Int
  genre       Genre      @relation(fields: [genreId], references: [id])
  explicit    Boolean?
  popularity  Int?
  playlists   Playlist[] @relation("PlaylistSongs")
  reviews     Review[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  @@unique([title, albumId, artistId])
}

model Playlist {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  listenerId  Int
  listener    Listener @relation(fields: [listenerId], references: [id], onDelete: Cascade)
  songs       Song[]   @relation("PlaylistSongs")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([name, listenerId])
}

model Review {
  id        Int      @id @default(autoincrement())
  content   String
  score     Int
  songId    Int
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  listenerId Int
  listener  Listener @relation(fields: [listenerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([songId, listenerId])
}